{
  "layer": "top",
  "position": "top",
  "height": 30,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["battery", "network", "pulseaudio", "tray"],

  "battery": {
    "bat": "BAT1",
    "adapter": "ACAD",
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "⚡ {capacity}%",
    "format-plugged": "🔌 {capacity}%",
    "format-alt": "{time}"
  },

  "clock": {
    "format": "{:%H:%M}"
  }
}
