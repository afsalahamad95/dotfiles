{
  "layer": "top",
  "position": "top",
  "height": 45,
  "spacing": 10, 
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["backlight", "backlight/slider", "pulseaudio", "network", "battery", "custom/activity"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚσ",
      "3": "ΎΒ╝",
      "4": "ΎΕκ",
      "5": "ΎΓΗ",
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },

  "battery": {
    "bat": "BAT1",
    "adapter": "ACAD",
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "ΎΘο  {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },

  "clock": {
    "format": "ΎΑΩ  {:%H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "backlight": {
    "format": "{icon}",
    "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
    "tooltip": false
  },

  "backlight/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "Ύγσ  Muted",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },

  "network": {
    "interface": "wlan0",
    "format-wifi": "ΎΘτ  {essid}",
    "format-ethernet": "≤░ΛΩ  {ipaddr}",
    "format-disconnected": "έγι  Offline",
    "tooltip-format": "{ifname} via {gwaddr} ≤░ΛΩ"
  },

  "custom/activity": {
    "interval": 2,
    "exec": "~/.config/waybar/scripts/activity.sh",
    "on-click": "kitty -e nmtui",
    "format": "ΎΙ│  {}",
    "tooltip": true
  }
}
