{
    "layer": "top",
    "position": "top",
    "height": 45,
    "spacing": 8,
    "margin-top": 10,
    "margin-left": 15,
    "margin-right": 15,

    "modules-left": [
        "hyprland/workspaces",
        "group/devlinks"
    ],
    "modules-center": [
        "clock",
        "custom/weather"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "group/audio",
        "group/display",
        "battery",
        "group/power"
    ],

    // =========================================================
    // WORKSPACES
    // =========================================================
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "active": "¾░«»",
            "default": "¾░ŖĀ",
            "urgent": "¾░Ć”"
        }
    },

    // =========================================================
    // DEV QUICKLINKS DRAWER
    // =========================================================
    "group/devlinks": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 400,
            "children-class": "devlink-child",
            "transition-left-to-right": true
        },
        "modules": [
            "custom/devlinks-leader",
            "custom/quicklink_kitty",
            "custom/quicklink_golang",
            "custom/quicklink_github",
            "custom/quicklink_docker",
            "custom/waypaper"
        ]
    },
    "custom/devlinks-leader": {
        "format": "¾░¦«",
        "tooltip": true,
        "tooltip-format": "Dev Shortcuts"
    },
    "custom/quicklink_kitty": {
        "format": "¾░åŹ",
        "on-click": "kitty &",
        "tooltip": true,
        "tooltip-format": "Terminal"
    },
    "custom/quicklink_golang": {
        "format": "¾░¤ō",
        "on-click": "kitty --working-directory ~/go/src &",
        "tooltip": true,
        "tooltip-format": "Go Workspace"
    },
    "custom/quicklink_github": {
        "format": "¾░Ŗż",
        "on-click": "xdg-open https://github.com/ &",
        "tooltip": true,
        "tooltip-format": "GitHub"
    },
    "custom/quicklink_docker": {
        "format": "¾░Ī©",
        "on-click": "kitty -e docker ps -a &",
        "tooltip": true,
        "tooltip-format": "Docker"
    },
    "custom/waypaper": {
        "format": "¾░Ėē",
        "on-click": "waypaper &",
        "tooltip": true,
        "tooltip-format": "Wallpaper"
    },

    // =========================================================
    // HARDWARE METRICS (Permanently Expanded & Visible)
    // =========================================================
    "cpu": {
        "interval": 3,
        "format": "¾░╗Ā {usage}%",
        "tooltip": true,
        "tooltip-format": "Freq: {avg_frequency} GHz\nLoad: {load}"
    },
    "memory": {
        "interval": 5,
        "format": "¾░Źø {used:.1f}G",
        "tooltip": true,
        "tooltip-format": "Swap: {swapUsed:.2f} / {swapTotal:.2f} GiB\nFree: {avail:.2f} GiB"
    },
    "temperature": {
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 80,
        "interval": 5,
        "format": "¾░öÅ {temperatureC}┬░C",
        "format-critical": "¾░Ėü {temperatureC}┬░C",
        "tooltip": true,
        "tooltip-format": "Critical threshold: 80┬░C"
    },

    // =========================================================
    // AUDIO & DISPLAY
    // =========================================================
    "group/audio": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 400,
            "children-class": "audio-child",
            "transition-left-to-right": false
        },
        "modules": ["pulseaudio", "pulseaudio/slider"]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¾░Ø¤ Muted",
        "format-icons": {
            "headphone": "¾░ŗŗ",
            "headset": "¾░ŗÄ",
            "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol &",
        "tooltip-format": "Volume: {volume}%\nDevice: {desc}"
    },
    "pulseaudio/slider": {
        "min": 0, "max": 100, "orientation": "horizontal"
    },

    "group/display": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 400,
            "children-class": "display-child",
            "transition-left-to-right": false
        },
        "modules": ["backlight", "backlight/slider"]
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["¾░ā×", "¾░ā¤", "¾░āĀ"],
        "on-scroll-up": "brightnessctl -e4 -n2 set 5%+",
        "on-scroll-down": "brightnessctl -e4 -n2 set 5%-",
        "tooltip-format": "Brightness: {percent}%"
    },
    "backlight/slider": {
        "min": 0, "max": 100, "orientation": "horizontal"
    },

    // =========================================================
    // BATTERY
    // =========================================================
    "battery": {
        "states": { "good": 80, "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░Üź {capacity}%",
        "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
        "tooltip-format": "{capacity}%\n{timeTo}\nDraw: {power}W"
    },

    // =========================================================
    // POWER DRAWER
    // =========================================================
    "group/power": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 400,
            "children-class": "power-child",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power-leader",
            "custom/lock",
            "custom/reboot",
            "custom/shutdown"
        ]
    },
    "custom/power-leader": {
        "format": "¾░Éź",
        "tooltip-format": "Power Menu"
    },
    "custom/lock": {
        "format": "¾░īŠ",
        "on-click": "hyprlock &",
        "tooltip-format": "Lock screen"
    },
    "custom/reboot": {
        "format": "¾░£ē",
        "on-click": "systemctl reboot",
        "tooltip-format": "Reboot"
    },
    "custom/shutdown": {
        "format": "¾░żå",
        "on-click": "systemctl poweroff",
        "tooltip-format": "Shutdown"
    },

    // =========================================================
    // CLOCK & WEATHER (Interactive Large Calendar)
    // =========================================================
    "clock": {
        "format": "¾░źö {:%H:%M  %a, %b %e}",
        "tooltip-format": "<tt><span size='12pt' font='JetBrainsMono Nerd Font'>{calendar}</span></tt>",
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#89b4fa'><b>{}</b></span>",
                "days":       "<span color='#cdd6f4'><b>{}</b></span>",
                "weeks":      "<span color='#a6e3a1'><b>W{}</b></span>",
                "weekdays":   "<span color='#f9e2af'><b>{}</b></span>",
                "today":      "<span color='#f38ba8'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 1800,
        "exec": "~/.config/waybar/scripts/weather.py",
        "return-type": "json"
    }
}
